{
    "name": "@hipay/hipay-enterprise-sdk-nodejs",
    "description": "The HiPay Enterprise SDK for NodeJS is a library for developers who want to integrate HiPay Enterprise payment methods to any NodeJS platform.",
    "version": "1.6.0",
    "license": "Apache-2.0",
    "author": {
        "name": "HiPay",
        "url": "http://www.hipay.com",
        "email": "support.tpp@hipay.com"
    },
    "homepage": "https://hipay.com/product-enterprise/",
    "main": "HiPay.js",
    "keywords": [
        "hipay",
        "payment",
        "payment method"
    ],
    "engines": {
        "node": ">=16.0.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/hipay/hipay-enterprise-sdk-nodejs.git"
    },
    "scripts": {
        "test": "jest",
        "fix": "eslint . --fix",
        "lint": "eslint ."
    },
    "dependencies": {
        "axios": "^1.11.0",
        "uuid": "^11.1.0"
    },
    "devDependencies": {
        "@stryker-mutator/core": "^8.6.0",
        "@stryker-mutator/jest-runner": "^8.6.0",
        "eslint": "^8.57.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-plugin-import": "^2.31.0",
        "jest": "^29.7.0",
        "jest-html-reporters": "^3.1.7",
        "jest-sonar-reporter": "^2.0.0",
        "lint-staged": "^15.4.0",
        "lodash.isequal": "^4.5.0",
        "prettier": "^3.6.2",
        "supertest": "^7.0.0"
    },
    "jest": {
        "testEnvironment": "node",
        "coverageReporters": [
            "lcov",
            "text"
        ],
        "testResultsProcessor": "jest-sonar-reporter",
        "collectCoverage": true,
        "moduleNameMapper": {
            "axios": "axios/dist/node/axios.cjs"
        }
    },
    "jestSonar": {
        "reportPath": "reports",
        "indent": 4,
        "reportFile": "test-report.xml"
    }
}
